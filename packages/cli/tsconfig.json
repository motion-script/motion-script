{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        // NodeNext so emitted output is runnable directly by Node's ESM loader
        // (this is a CLI executed by `node`, not bundled like the other
        // packages). It requires explicit `.js` extensions on relative imports.
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2023"],
        "types": ["node"],
        "paths": {
            "@/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src/**/*"
    ]
}
