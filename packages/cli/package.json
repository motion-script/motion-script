{
  "name": "@motion-script/cli",
  "version": "1.1.0",
  "description": "Headless command-line exporter for Motion Script projects (ms list / ms export).",
  "license": "Apache-2.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ms": "dist/cli.js",
    "motion-script": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rimraf --glob dist .turbo *.tsbuildinfo",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "kleur": "^4.1.5",
    "minimist": "^1.2.8",
    "playwright": "^1.50.0"
  },
  "peerDependencies": {
    "vite": "catalog:"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/minimist": "^1.2.5",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "rimraf": "^6.1.3",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:"
  }
}
