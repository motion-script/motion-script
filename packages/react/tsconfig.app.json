{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "jsx": "preserve",
    "types": [
      "vite/client"
    ],
    "noEmit": true,
    // Tighten dead-code hygiene for the whole package (lib + examples).
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "src",
    "examples"
  ]
}
