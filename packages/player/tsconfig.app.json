{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "lib": [
      "DOM",
      "ES2022"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "jsx": "preserve",
    "types": [
      "vite/client"
    ],
    "noEmit": true
  },
  "include": [
    "src",
    "examples",
  ]
}