{
  "name": "@motion-script/player",
  "description": "Visual editor and preview app for Motion Script projects, with timeline scrubbing, scene inspection, and video export.",
  "version": "1.0.0",
  "type": "module",
  "author": "Motion Script",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "clean": "rimraf --glob dist .turbo *.tsbuildinfo",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:app": "vite build --config vite.config.app.ts",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/motion-script-player.js",
  "types": "./dist/motion-script-player.d.ts",
  "exports": {
    ".": {
      "types": "./dist/motion-script-player.d.ts",
      "import": "./dist/motion-script-player.js"
    },
    "./style.css": "./dist/motion-script-player.css",
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@motion-script/core": "workspace:*",
    "@motion-script/react": "workspace:*",
    "@motion-script/web": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "@motion-script/canvaskit": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react-resizable-panels": "^4.11.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "use-sync-external-store": "^1.6.0",
    "wavesurfer.js": "^7.12.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@motion-script/core": "workspace:*",
    "@motion-script/react": "workspace:*",
    "@motion-script/web": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "globals": "^16.5.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "shadcn": "^4.10.0"
  }
}
